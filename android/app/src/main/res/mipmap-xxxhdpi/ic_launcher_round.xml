<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#0D1526"/>
            <corners android:radius="0dp"/>
        </shape>
    </item>
    <item
        android:top="20dp"
        android:left="20dp"
        android:right="20dp"
        android:bottom="20dp">
        <shape android:shape="oval">
            <solid android:color="#1565C0"/>
        </shape>
    </item>
    <item
        android:top="28dp"
        android:left="28dp"
        android:right="28dp"
        android:bottom="28dp">
        <shape android:shape="rectangle">
            <solid android:color="#F5A623"/>
            <corners android:radius="4dp"/>
        </shape>
    </item>
</layer-list>
